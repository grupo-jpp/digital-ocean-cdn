{
  "fields": {
    "connection": {
      "type": "link",
      "tooltip": true,
      "view": "views/fields/link"
    },
    "doPathPrefix": { "type": "varchar", "default": "" },
    "doCdnEndpoint": { "type": "varchar", "tooltip": true },
    "syncEnabled": { "type": "bool", "default": false, "tooltip": true },
    "syncDirection": {
      "type": "enum",
      "options": ["upload", "download", "both"],
      "default": "upload",
      "tooltip": true
    },
    "syncOnFileSave": { "type": "bool", "default": true, "tooltip": true },
    "syncDeleteRemote": { "type": "bool", "default": false, "tooltip": true },
    "lastSyncAt": { "type": "datetime", "readOnly": true },
    "lastSyncStatus": { "type": "varchar", "readOnly": true }
  },
  "links": {
    "connection": {
      "type": "belongsTo",
      "entity": "Connection",
      "foreign": "storages"
    }
  }
}
